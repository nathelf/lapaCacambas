# ─── Servidor ────────────────────────────────────────────────────────────────
BACKEND_PORT=3333
NODE_ENV=development

# ─── Supabase (obrigatórios) ──────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Webhook bancário (opcional) ─────────────────────────────────────────────
BANCO_WEBHOOK_SECRET=

# ─── Maps / Rotas inteligentes ────────────────────────────────────────────────
# Chave usada no backend para chamar Google Routes API.
# Em desenvolvimento, pode reaproveitar a mesma da VITE_GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_API_KEY="AIzaSyBh7B0GW0E1aNY71013EMyMIaqLdDYbpuY"

# ─── Fiscal — overrides opcionais (não obrigatórios em produção) ─────────────
#
# FISCAL_PROVIDER_OVERRIDE
#   Force um provider específico, independente da config no banco.
#   Valores: mock | focus | atendenet | http
#   Use "mock" em testes automatizados (CI) para não chamar APIs externas.
#
# FISCAL_PROVIDER_OVERRIDE=mock

# FISCAL_AMBIENTE_OVERRIDE
#   Force o ambiente fiscal, sobrescrevendo o valor da tabela configuracoes_fiscais.
#   Use "homologacao" em staging para nunca emitir nota fiscal real por engano.
#
# FISCAL_AMBIENTE_OVERRIDE=homologacao

# ── Focus NFe (sandbox: https://homologacao.focusnfe.com.br) ─────────────────
#   Token direto — autenticação HTTP Basic (token como username, senha vazia).
#   Obtenha em: https://app.focusnfe.com.br → Empresa → Tokens de API
#
# FISCAL_FOCUS_TOKEN=seu_token_sandbox_aqui

# ── AtendeNet (sandbox: solicitar ao fornecedor) ─────────────────────────────
#   Sobrescreve api_base_url, login e senha da tabela configuracoes_fiscais.
#   Útil para CI sem alterar banco de dados.
#
# FISCAL_ATENDENET_BASE_URL=https://sandbox.atendenet.com.br
# FISCAL_ATENDENET_LOGIN=usuario_sandbox
# FISCAL_ATENDENET_SENHA=senha_sandbox
